            "height": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Height",
              "description": "The height of the video"
            },
            "file_name": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "examples": [
                "z9RV14K95DvU.png"
              ],
              "title": "File Name",
              "description": "The name of the file. It will be auto-generated if not provided."
