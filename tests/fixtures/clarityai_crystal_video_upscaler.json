            "num_frames": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Num Frames",
              "description": "The number of frames in the video"
            }
          },
          "required": [
            "url"
          ],
          "x-fal-order-properties": [
            "url",
            "content_type",
            "file_name",
            "file_size",
            "width",
            "height",
            "fps",
            "duration",
