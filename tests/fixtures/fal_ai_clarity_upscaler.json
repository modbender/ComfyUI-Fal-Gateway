    "pinned": false
  },
  "openapi": {
    "openapi": "3.0.4",
    "info": {
      "title": "Queue OpenAPI for fal-ai/clarity-upscaler",
      "version": "1.0.0",
      "description": "The OpenAPI schema for the fal-ai/clarity-upscaler queue.",
      "x-fal-metadata": {
        "endpointId": "fal-ai/clarity-upscaler",
        "category": "image-to-image",
        "thumbnailUrl": "https://storage.googleapis.com/falserverless/gallery/controlnet-tile-upscaler.webp",
        "playgroundUrl": "https://fal.ai/models/fal-ai/clarity-upscaler",
        "documentationUrl": "https://fal.ai/models/fal-ai/clarity-upscaler/api"
      }
    },
    "components": {
      "securitySchemes": {
        "apiKeyAuth": {
          "type": "apiKey",
          "in": "header",
          "name": "Authorization",
          "description": "Fal Key"
        }
      },
      "schemas": {
        "QueueStatus": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "IN_QUEUE",
                "IN_PROGRESS",
                "COMPLETED"
              ]
            },
            "request_id": {
              "type": "string",
              "description": "The request id."
            },
            "response_url": {
              "type": "string",
              "description": "The response url."
            },
            "status_url": {
              "type": "string",
              "description": "The status url."
            },
            "cancel_url": {
              "type": "string",
              "description": "The cancel url."
            },
            "logs": {
              "type": "object",
              "description": "The logs.",
              "additionalProperties": true
            },
            "metrics": {
              "type": "object",
              "description": "The metrics.",
              "additionalProperties": true
            },
            "queue_position": {
              "type": "integer",
              "description": "The queue position."
            }
          },
          "required": [
            "status",
            "request_id"
          ]
        },
        "ClarityUpscalerInput": {
          "required": [
            "image_url"
          ],
          "title": "Input",
          "x-fal-order-properties": [
            "image_url",
            "prompt",
            "upscale_factor",
            "negative_prompt",
            "creativity",
            "resemblance",
            "guidance_scale",
            "num_inference_steps",
            "seed",
            "enable_safety_checker"
          ],
          "properties": {
            "seed": {
              "title": "Seed",
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "\n            The same seed and the same prompt given to the same version of Stable Diffusion\n            will output the same image every time.\n        "
            },
            "upscale_factor": {
              "default": 2,
              "title": "Upscale Factor",
              "minimum": 1,
              "maximum": 4,
              "type": "number",
              "description": "The upscale factor"
            },
            "enable_safety_checker": {
              "default": true,
              "title": "Enable Safety Checker",
              "type": "boolean",
              "description": "If set to false, the safety checker will be disabled."
            },
            "image_url": {
              "examples": [
                "https://storage.googleapis.com/falserverless/gallery/NOCA_Mick-Thompson.resized.resized.jpg"
              ],
              "title": "Image Url",
              "type": "string",
              "description": "The URL of the image to upscale."
            },
            "creativity": {
              "default": 0.35,
              "title": "Creativity",
              "minimum": 0,
              "maximum": 1,
              "type": "number",
              "description": "\n            The creativity of the model. The higher the creativity, the more the model will deviate from the prompt.\n            Refers to the denoise strength of the sampling.\n        "
            },
            "num_inference_steps": {
              "default": 18,
              "title": "Num Inference Steps",
              "minimum": 4,
              "maximum": 50,
              "type": "integer",
              "description": "The number of inference steps to perform."
            },
            "negative_prompt": {
              "default": "(worst quality, low quality, normal quality:2)",
              "examples": [
                "(worst quality, low quality, normal quality:2)"
              ],
              "title": "Negative Prompt",
              "type": "string",
              "description": "The negative prompt to use. Use it to address details that you don't want in the image."
            },
            "resemblance": {
              "default": 0.6,
              "title": "Resemblance",
              "minimum": 0,
              "maximum": 1,
              "type": "number",
              "description": "\n            The resemblance of the upscaled image to the original image. The higher the resemblance, the more the model will try to keep the original image.\n            Refers to the strength of the ControlNet.\n        "
            },
            "guidance_scale": {
              "default": 4,
              "title": "Guidance scale (CFG)",
              "minimum": 0,
              "maximum": 20,
              "type": "number",
              "description": "\n            The CFG (Classifier Free Guidance) scale is a measure of how close you want\n            the model to stick to your prompt when looking for a related image to show you.\n        "
            },
            "prompt": {
              "default": "masterpiece, best quality, highres",
              "examples": [
                "masterpiece, best quality, highres"
              ],
              "title": "Prompt",
              "type": "string",
              "description": "The prompt to use for generating the image. Be as descriptive as possible for best results."
            }
          },
          "type": "object"
        },
        "ClarityUpscalerOutput": {
          "required": [
            "image",
            "seed",
            "timings"
          ],
          "title": "Output",
          "x-fal-order-properties": [
            "image",
            "seed",
            "timings"
          ],
          "properties": {
            "seed": {
              "title": "Seed",
              "type": "integer",
              "description": "The seed used to generate the image."
            },
            "image": {
              "$ref": "#/components/schemas/Image",
              "description": "The URL of the generated image."
            },
            "timings": {
              "title": "Timings",
              "additionalProperties": {
                "type": "number"
              },
              "type": "object",
              "description": "The timings of the different steps in the workflow."
            }
          },
          "type": "object"
        },
        "Image": {
          "required": [
            "url"
          ],
          "title": "Image",
          "x-fal-order-properties": [
            "url",
            "content_type",
            "file_name",
            "file_size",
            "width",
            "height"
          ],
          "properties": {
            "file_size": {
              "examples": [
                4404019
              ],
              "title": "File Size",
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The size of the file in bytes."
            },
            "url": {
              "title": "Url",
              "type": "string",
              "description": "The URL where the file can be downloaded from."
            },
            "file_name": {
              "examples": [
                "z9RV14K95DvU.png"
              ],
              "title": "File Name",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The name of the file. It will be auto-generated if not provided."
            },
            "content_type": {
              "examples": [
                "image/png"
              ],
              "title": "Content Type",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The mime type of the file."
            },
            "width": {
              "examples": [
                1024
              ],
              "title": "Width",
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The width of the image in pixels."
            },
            "height": {
              "examples": [
                1024
              ],
              "title": "Height",
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "description": "The height of the image in pixels."
            }
          },
          "type": "object",
          "description": "Represents an image file."
        }
      }
    },
    "paths": {
      "/fal-ai/clarity-upscaler/requests/{request_id}/status": {
        "get": {
          "parameters": [
            {
              "name": "request_id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string",
                "description": "Request ID"
              }
            },
            {
              "name": "logs",
              "in": "query",
              "required": false,
              "schema": {
                "type": "number",
                "description": "Whether to include logs (`1`) in the response or not (`0`)."
              }
            }
          ],
          "responses": {
            "200": {
              "description": "The request status.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/QueueStatus"
                  }
                }
              }
            }
          }
        }
      },
      "/fal-ai/clarity-upscaler/requests/{request_id}/cancel": {
        "put": {
          "parameters": [
            {
              "name": "request_id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string",
                "description": "Request ID"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "The request was cancelled.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "success": {
                        "type": "boolean",
                        "description": "Whether the request was cancelled successfully."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "/fal-ai/clarity-upscaler": {
        "post": {
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClarityUpscalerInput"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "The request status.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/QueueStatus"
                  }
                }
              }
            }
          }
        }
      },
      "/fal-ai/clarity-upscaler/requests/{request_id}": {
        "get": {
          "parameters": [
            {
              "name": "request_id",
              "in": "path",
              "required": true,
              "schema": {
                "type": "string",
                "description": "Request ID"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Result of the request.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ClarityUpscalerOutput"
                  }
                }
              }
            }
          }
        }
      }
    },
    "servers": [
      {
        "url": "https://queue.fal.run"
      }
    ],
    "security": [
      {
        "apiKeyAuth": []
      }
    ]
  }
}