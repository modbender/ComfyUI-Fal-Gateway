    "info": {
      "title": "Queue OpenAPI for clarityai/crystal-upscaler",
      "version": "1.0.0",
      "description": "The OpenAPI schema for the clarityai/crystal-upscaler queue.",
      "x-fal-metadata": {
        "endpointId": "clarityai/crystal-upscaler",
        "category": "image-to-image",
        "thumbnailUrl": "https://v3b.fal.media/files/b/kangaroo/MXXDFIdMKdUafM9WsY5sk_10934786a1c846acbb01d7ae9c2bdab1.jpg",
