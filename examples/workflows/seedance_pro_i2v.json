{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "example.png"
    }
  },
  "2": {
    "class_type": "FalGatewayI2V",
    "inputs": {
      "model_id": "bytedance/seedance-2.0/image-to-video",
      "prompt": "REPLACE THIS — describe the motion you want, e.g. 'subtle camera push-in, gentle wind through fur, soft cinematic light'",
      "image": ["1", 0]
    }
  },
  "3": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["2", 0],
      "audio": ["2", 2],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "FalGateway_Seedance",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true
    }
  }
}
